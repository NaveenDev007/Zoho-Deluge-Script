string standalone.get_all_the_Instance_in_client_script()
{
queryMap = Map();
queryMap.put("select_query","select Name, id from Course_Instance where Layout is not null order by Name limit 2000");
response = invokeurl
[
	url :"https://crmplus.zoho.sa/crm/v6/coql"
	type :POST
	parameters:queryMap.toString()
	connection:"zcrm_coql"
];
info response;
if(response == null || response.isEmpty())
{
	return "0";
}
response = response.get("data");
Instance_List = List();
for each  instance in response
{
	Instance_List.add(instance.get("Name"));
}
return Instance_List.toString();
}
