if(AppStatus == "Pre Screen Session" || AppStatus == "Pre Screen Rescheduled" || AppStatus == "Pre Screen Did not Attended" || AppStatus == "Pre Screen Cancelled by Employer" || AppStatus == "Pre Screen Attended" || AppStatus == "Pre Screen Pass" || AppStatus == "Pre Screen Did Not Pass")
